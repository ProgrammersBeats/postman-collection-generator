{
    "name": "yourvendor/laravel-postman-generator",
    "description": "Generate Postman collections from Laravel routes with Sanctum authentication support and multiple grouping strategies",
    "keywords": [
        "laravel",
        "postman",
        "api",
        "collection",
        "generator",
        "sanctum",
        "documentation"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "your@email.com"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "YourVendor\\PostmanGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YourVendor\\PostmanGenerator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "YourVendor\\PostmanGenerator\\PostmanGeneratorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
